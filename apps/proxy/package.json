{
  "name": "@token-shuffle/proxy",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "bin": {
    "token-shuffle": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-storage-migrations.mjs",
